{
  "project": "CCL",
  "workstream": "Test Fix",
  "task_type": "test_gate",
  "objective": "Fix a focused failing test or test helper without broad refactor.",
  "required_context": {
    "dna": true,
    "agent_skills": true,
    "latest_prs": 10,
    "project_ledger": true
  },
  "allowed_paths": [
    "crates/ccl-core/src/**",
    "crates/ccl-cli/src/**",
    "crates/**/tests/**",
    "ledger/project-ledger.md"
  ],
  "forbidden_paths": [
    "Cargo.toml",
    "Cargo.lock",
    "ci/**",
    ".github/**",
    "LICENSE-*",
    "NOTICE",
    "docs/security/**",
    "CCL_DNA.md"
  ],
  "required_validation": [
    "cargo fmt --check",
    "cargo test",
    "cargo clippy --all-targets --all-features -- -D warnings"
  ],
  "validation": {
    "commands": [
      {
        "id": "cargo-fmt",
        "program": "cargo",
        "args": ["fmt", "--check"],
        "required": true,
        "wall_timeout_seconds": 300
      },
      {
        "id": "cargo-test",
        "program": "cargo",
        "args": ["test"],
        "required": true,
        "wall_timeout_seconds": 300
      },
      {
        "id": "cargo-clippy",
        "program": "cargo",
        "args": ["clippy", "--all-targets", "--all-features", "--", "-D", "warnings"],
        "required": true,
        "wall_timeout_seconds": 300
      }
    ]
  },
  "scope_limits": {
    "max_changed_files": 8,
    "max_diff_lines": 400
  },
  "environment_policy": {
    "mode": "warn",
    "allow": [
      "PATH",
      "SystemRoot",
      "WINDIR",
      "HOME",
      "USERPROFILE",
      "TMP",
      "TEMP",
      "NO_COLOR",
      "TERM"
    ],
    "deny": [
      "CCL_TEST_FORBIDDEN_ENV"
    ],
    "allow_prefixes": [
      "CARGO_TERM_"
    ],
    "deny_prefixes": [
      "CCL_TEST_DENY_"
    ],
    "redact_patterns": [
      "TOKEN",
      "SECRET",
      "PASSWORD",
      "KEY"
    ],
    "unknown": "warn"
  },
  "github_ci_as_evidence": false,
  "ledger_update_required": true,
  "verdicts": {
    "pass": "Focused test fixes stay inside allowed paths and local checks pass.",
    "pass_with_warnings": "Focused test fixes pass with non-blocking warnings.",
    "fail": "Focused test fixes violated scope or required validation."
  }
}
